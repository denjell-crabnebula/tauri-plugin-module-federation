{
	"productName": "example-host",
	"version": "0.1.0",
	"identifier": "dev.crabnebula.module-federation",
	"build": {
		"frontendDist": "../dist",
		"devUrl": "http://localhost:3001",
		"beforeDevCommand": "pnpm rsbuild dev",
		"beforeBuildCommand": "pnpm rsbuild build"
	},
	"app": {
		"windows": [
			{
				"title": "example-host",
				"width": 800,
				"height": 600,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	},
	"$schema": "../node_modules/@tauri-apps/cli/schema.json"
}
